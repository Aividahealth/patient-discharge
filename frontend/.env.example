# Backend API URL
# Development: http://localhost:3000
# Production: Your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Web3Forms access key for the marketing site contact + newsletter forms.
# Create a free key at https://web3forms.com (tie it to the destination inbox,
# e.g. ai@aividahealth.ai). This value is public by design.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
